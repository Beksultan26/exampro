{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build:server": "tsc",
    "build:client": "npm --prefix ../client install && npm --prefix ../client run build",
    "copy:client": "rimraf public && shx mkdir -p public && shx cp -r ../client/dist/* public/",
    "build": "npm run build:client && npm run copy:client && npm run build:server && npx prisma generate",
    "start": "node dist/server.js",
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "prisma": "^5.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^8.0.0",
    "rimraf": "^6.0.1",
    "shx": "^0.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}